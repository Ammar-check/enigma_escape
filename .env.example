# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP — Microsoft 365 / Office 365 (TLS port 587)
# Never commit real passwords. Use Vercel Environment Variables for production.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.sa
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.sa

# Optional: BCC staff inbox on every booking email
BOOKING_BCC_EMAIL=info@yourdomain.sa

# Optional: protect POST /api/bookings/notify (cancel/pending emails from webhook/automation)
BOOKING_NOTIFY_SECRET=generate-a-long-random-string
